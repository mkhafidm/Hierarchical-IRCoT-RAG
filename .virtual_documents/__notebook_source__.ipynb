import subprocess
subprocess.run(["apt-get", "install", "-y", "openssh-server"], capture_output=True)
subprocess.run(["/etc/init.d/ssh", "start"], capture_output=True)
print("SSH ready!")


import os, urllib.request
os.makedirs("/root/.ssh", exist_ok=True)
urllib.request.urlretrieve(
    "https://raw.githubusercontent.com/mkhafidm/kaggle-key/refs/heads/main/kaggle_key.pub",
    "/root/.ssh/authorized_keys"
)
os.chmod("/root/.ssh/authorized_keys", 0o600)
print("Key ready!")


import urllib.request, tarfile, os
urllib.request.urlretrieve(
    "https://github.com/openziti/zrok/releases/download/v2.0.4/zrok_2.0.4_linux_amd64.tar.gz",
    "/tmp/zrok.tar.gz"
)
with tarfile.open("/tmp/zrok.tar.gz") as tar:
    tar.extractall("/usr/local/bin/")
os.chmod("/usr/local/bin/zrok2", 0o755)
print("zrok2 binary ready!")


import subprocess, shutil, os
# Fresh start
shutil.rmtree(os.path.expanduser("~/.zrok"), ignore_errors=True)
result = subprocess.run(["zrok2", "enable", "--headless", "F4GsU9aqam8d"], capture_output=True, text=True)
print(result.stdout)
print(result.stderr)


import subprocess
proc = subprocess.Popen(
    ["zrok2", "share", "private", "--backend-mode", "tcpTunnel", "localhost:22", "--headless"],
    stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True
)
for i in range(30):
    line = proc.stdout.readline()
    print(line, end='')
print(f"PID: {proc.pid}")





